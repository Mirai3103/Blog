@model BlogApp.Models.Post
<div class="hidden duration-700 ease-in-out" data-carousel-item>
    <div class="absolute flex flex-col justify-end w-full h-full top-0 left-0 bg-gray-800 bg-opacity-60 z-30">
        <div class="py-4 px-16 flex flex-col">
            <a asp-action="PostDetail" asp-route-slug="@Model.Slug">
                <h5 class="my-2 text-2xl line-clamp-2 font-bold tracking-tight dark:text-gray-900 text-white">
                    @Model.Title
                </h5>
            </a>
            <p class="my-3 text-sm font-normal line-clamp-3 dark:text-gray-700 text-gray-200">
                @Model.Summary
            </p>
        </div>
    </div>
    <img src="@Model.ThumbnailUrl" class="absolute block w-full -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2"
        alt="@Model.Title" />
</div>